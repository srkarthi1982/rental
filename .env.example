# Local (SQLite)
ASTRO_DB_REMOTE_URL=file:.astro/content.db

# Production (Turso/libSQL)
ASTRO_DB_REMOTE_URL=libsql://your-db-host.turso.io
ASTRO_DB_APP_TOKEN=your-app-token
# If Astro Studio is used, set this too:
# ASTRO_STUDIO_APP_TOKEN=your-studio-token

# Parent app routing and notifications
# Local dev should point to the parent app running on port 2000.
PARENT_APP_URL=http://localhost:2000
ANSIVERSA_WEBHOOK_SECRET=your-webhook-secret
# PARENT_NOTIFICATION_WEBHOOK_URL=https://ansiversa.com/api/webhooks/notifications.json

# Core app routing
ANSIVERSA_COOKIE_DOMAIN=localhost
PUBLIC_ROOT_APP_URL=http://localhost:2000

# Production values:
# ANSIVERSA_COOKIE_DOMAIN=ansiversa.com
# PUBLIC_ROOT_APP_URL=https://ansiversa.com
# PARENT_APP_URL=https://ansiversa.com

# Dev helpers (optional; DEV-only, never production)
DEV_BYPASS_AUTH=true
DEV_BYPASS_USER_ID=dev-user
DEV_BYPASS_EMAIL=dev@local
DEV_BYPASS_ROLE_ID=1
