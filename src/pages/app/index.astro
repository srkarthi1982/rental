---
import { AvButton, AvCard, AvContainer } from "@ansiversa/components";
import AppShell from "../../layouts/AppShell.astro";
import { APP_META } from "../../app.meta";

const title = `${APP_META.name} App`;
const description = "Protected workspace entry for the Rental platform.";

const nextSteps = [
  "Add category selection for car, home, equipment, and future rental verticals.",
  "Design the Rental database schema before adding business logic.",
  "Build the V1 car rental flow while keeping the platform architecture generic.",
];
---

<AppShell title={title} description={description}>
  <section class="av-section">
    <AvContainer>
      <div class="av-auth-stack-lg">
        <AvCard className="av-auth-card">
          <div class="av-auth-stack-md">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Rental Workspace</p>
              <h1 class="av-section-title">{APP_META.name}</h1>
              <p class="av-text-soft">
                This is the protected entry point for the Rental platform. Authenticated users will
                choose a rental category here before continuing into the approved product flow.
              </p>
            </div>

            <div class="av-row-wrap">
              <AvButton href="/">Back to landing</AvButton>
              <AvButton href="/signout" variant="ghost">Sign out</AvButton>
            </div>
          </div>
        </AvCard>

        <div class="grid gap-4 md:grid-cols-3">
          {nextSteps.map((step) => (
            <AvCard variant="soft" className="av-auth-stack-sm">
              <h2 class="av-card-heading">Next phase</h2>
              <p class="av-text-soft">{step}</p>
            </AvCard>
          ))}
        </div>
      </div>
    </AvContainer>
  </section>
</AppShell>
