---
import {
  AvButton,
  AvCard,
  AvContainer,
  AvEmptyState,
  AvInput,
  AvSelect,
  AvTextarea,
} from "@ansiversa/components";
import AppShell from "../../layouts/AppShell.astro";
import CreateDrawer from "../../components/drawers/CreateDrawer.astro";
import { server } from "../../actions";

let cars: any[] = [];
let customers: any[] = [];
let loadError: string | null = null;
let customerLoadError: string | null = null;

try {
  const result = await Astro.callAction(server.listRentalCars, {});
  cars = Array.isArray(result?.data) ? result.data : [];
} catch (error) {
  loadError = error instanceof Error ? error.message : String(error);
}

try {
  const result = await Astro.callAction(server.listRentalCustomers, {});
  customers = Array.isArray(result?.data) ? result.data : [];
} catch (error) {
  customerLoadError = error instanceof Error ? error.message : String(error);
}

const initialState = {
  cars,
  customers,
  loadError,
  customerLoadError,
};
---

<AppShell title="Rental Workspace | Rental" description="Manage rental workspace records.">
  <section class="av-section">
    <AvContainer>
      <div
        class="av-auth-stack-lg"
        x-data="$store.rentalCars"
        x-init="initializeCarsPage($el.dataset.initial)"
        data-initial={JSON.stringify(initialState)}
      >
        <AvCard className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Rental Workspace</p>
              <h1 class="av-section-title" x-text="activeViewTitle()">Cars</h1>
              <p class="av-text-soft">Manage the rental records for your business workspace.</p>
            </div>
            <div class="av-row-wrap">
              <AvButton type="button" @click="openActiveCreateDrawer()">
                <span x-text="activeCreateLabel()">Add Car</span>
              </AvButton>
            </div>
          </div>

          <div class="app-tabs" role="tablist" aria-label="Rental workspace sections">
            <button
              type="button"
              class="app-tab"
              :class="{ 'app-tab--active': isActiveView('cars') }"
              role="tab"
              :aria-selected="isActiveView('cars')"
              @click="setActiveView('cars')"
            >
              Cars
            </button>
            <button
              type="button"
              class="app-tab"
              :class="{ 'app-tab--active': isActiveView('customers') }"
              role="tab"
              :aria-selected="isActiveView('customers')"
              @click="setActiveView('customers')"
            >
              Customers
            </button>
          </div>

          <template x-if="error">
            <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
          </template>
          <template x-if="customerError && isActiveView('customers')">
            <div class="av-alert av-alert-danger" role="status" x-text="customerError"></div>
          </template>
        </AvCard>

        <AvCard variant="soft" className="av-auth-stack-md" x-show="isActiveView('cars')">
          <div class="av-row-between app-row-top">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Cars</p>
              <h2 class="av-card-heading">Your cars</h2>
              <p class="av-text-soft">Each car is stored as a generic rental item with car details kept separately.</p>
            </div>
            <p class="av-text-soft"><span x-text="cars.length"></span> total</p>
          </div>

          <template x-if="!isLoading && cars.length === 0">
            <div class="av-auth-stack-sm">
              <AvEmptyState
                headline="No cars yet"
                description="No cars yet. Add your first car to get started."
              />
              <div class="av-row-wrap">
                <AvButton type="button" @click="openAddCarDrawer()">Add Car</AvButton>
              </div>
            </div>
          </template>

          <template x-if="!isLoading && cars.length > 0">
            <div class="app-cars-grid">
              <template x-for="car in cars" :key="car.id">
                <AvCard variant="soft" className="av-card--fullheight">
                  <div class="av-auth-stack-md">
                    <div class="av-row-between app-row-top">
                      <div class="av-auth-stack-xxs">
                        <h3 class="av-card-heading app-car-title" x-text="car.name"></h3>
                        <p class="av-text-soft" x-text="carSubtitle(car)"></p>
                      </div>
                      <span class="av-badge av-badge-soft" x-text="car.availabilityStatus || 'available'"></span>
                    </div>

                    <div class="app-signal-grid">
                      <div class="app-signal">
                        <span class="app-signal__label">Daily rate</span>
                        <strong x-text="formatMoney(car.baseDailyRate, car.currencyCode)"></strong>
                      </div>
                      <div class="app-signal">
                        <span class="app-signal__label">Deposit</span>
                        <strong x-text="formatMoney(car.depositAmount, car.currencyCode)"></strong>
                      </div>
                    </div>

                    <p class="av-text-soft" x-text="carMeta(car)"></p>
                  </div>
                </AvCard>
              </template>
            </div>
          </template>

          <template x-if="isLoading">
            <p class="av-text-soft">Loading cars...</p>
          </template>
        </AvCard>

        <AvCard variant="soft" className="av-auth-stack-md" x-show="isActiveView('customers')" x-cloak>
          <div class="av-row-between app-row-top">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Customers</p>
              <h2 class="av-card-heading">Customers</h2>
              <p class="av-text-soft">Store customer records for your rental business workspace.</p>
            </div>
            <p class="av-text-soft"><span x-text="customers.length"></span> total</p>
          </div>

          <template x-if="!isLoadingCustomers && customers.length === 0">
            <div class="av-auth-stack-sm">
              <AvEmptyState
                headline="No customers yet"
                description="No customers yet. Add your first customer to get started."
              />
              <div class="av-row-wrap">
                <AvButton type="button" @click="openAddCustomerDrawer()">Add Customer</AvButton>
              </div>
            </div>
          </template>

          <template x-if="!isLoadingCustomers && customers.length > 0">
            <div class="app-cars-grid">
              <template x-for="customer in customers" :key="customer.id">
                <AvCard variant="soft" className="av-card--fullheight">
                  <div class="av-auth-stack-md">
                    <div class="av-row-between app-row-top">
                      <div class="av-auth-stack-xxs">
                        <h3 class="av-card-heading app-car-title" x-text="customer.fullName"></h3>
                        <p class="av-text-soft" x-text="customerSubtitle(customer)"></p>
                      </div>
                      <span class="av-badge av-badge-soft" x-text="customer.status || 'active'"></span>
                    </div>

                    <div class="app-signal-grid">
                      <div class="app-signal">
                        <span class="app-signal__label">Email</span>
                        <strong x-text="customer.email || 'Email not added'"></strong>
                      </div>
                      <div class="app-signal">
                        <span class="app-signal__label">Phone</span>
                        <strong x-text="customer.phone || 'Phone not added'"></strong>
                      </div>
                    </div>

                    <p class="av-text-soft" x-text="customerMeta(customer)"></p>
                  </div>
                </AvCard>
              </template>
            </div>
          </template>

          <template x-if="isLoadingCustomers">
            <p class="av-text-soft">Loading customers...</p>
          </template>
        </AvCard>

        <template x-if="isAddCarDrawerOpen()">
          <CreateDrawer title="Add Car" description="Create one car rental item for your business.">
            <form id="add-car-form" class="av-auth-stack-md" novalidate @submit.prevent="submitAddCar()">
              <div class="app-form-grid">
                <div class="app-field-stack">
                  <AvInput
                    label="Name"
                    name="name"
                    x-model="addCarForm.name"
                    x-on:input="clearFieldError('name')"
                    required
                    placeholder="e.g. Toyota Corolla"
                  />
                  <template x-if="getFieldError('name')">
                    <p class="app-field-error" x-text="getFieldError('name')"></p>
                  </template>
                </div>
                <div class="app-field-stack">
                  <AvInput
                    label="Currency"
                    name="currencyCode"
                    x-model="addCarForm.currencyCode"
                    x-on:input="clearFieldError('currencyCode')"
                    required
                    maxlength="3"
                  />
                  <template x-if="getFieldError('currencyCode')">
                    <p class="app-field-error" x-text="getFieldError('currencyCode')"></p>
                  </template>
                </div>
              </div>

              <AvTextarea
                label="Description"
                name="description"
                rows={3}
                x-model="addCarForm.description"
                placeholder="Short internal description"
              />

              <div class="app-form-grid">
                <div class="app-field-stack">
                  <AvInput
                    label="Daily rate"
                    name="baseDailyRate"
                    type="number"
                    min="0"
                    step="0.01"
                    x-model="addCarForm.baseDailyRate"
                    x-on:input="clearFieldError('baseDailyRate')"
                    required
                  />
                  <template x-if="getFieldError('baseDailyRate')">
                    <p class="app-field-error" x-text="getFieldError('baseDailyRate')"></p>
                  </template>
                </div>
                <AvInput label="Deposit" name="depositAmount" type="number" min="0" step="0.01" x-model="addCarForm.depositAmount" />
              </div>

              <div class="app-form-grid">
                <div class="app-field-stack">
                  <AvInput
                    label="Plate number"
                    name="plateNumber"
                    x-model="addCarForm.plateNumber"
                    x-on:input="clearFieldError('plateNumber')"
                    required
                  />
                  <template x-if="getFieldError('plateNumber')">
                    <p class="app-field-error" x-text="getFieldError('plateNumber')"></p>
                  </template>
                </div>
                <div class="app-field-stack">
                  <AvInput
                    label="Make"
                    name="make"
                    x-model="addCarForm.make"
                    x-on:input="clearFieldError('make')"
                    required
                  />
                  <template x-if="getFieldError('make')">
                    <p class="app-field-error" x-text="getFieldError('make')"></p>
                  </template>
                </div>
                <div class="app-field-stack">
                  <AvInput
                    label="Model"
                    name="model"
                    x-model="addCarForm.model"
                    x-on:input="clearFieldError('model')"
                    required
                  />
                  <template x-if="getFieldError('model')">
                    <p class="app-field-error" x-text="getFieldError('model')"></p>
                  </template>
                </div>
                <AvInput label="Year" name="year" type="number" min="1900" step="1" x-model="addCarForm.year" />
              </div>

              <div class="app-form-grid">
                <AvInput label="Color" name="color" x-model="addCarForm.color" />
                <AvInput label="Fuel type" name="fuelType" x-model="addCarForm.fuelType" />
                <AvSelect label="Transmission" name="transmission" x-model="addCarForm.transmission">
                  <option value="">Select</option>
                  <option value="automatic">Automatic</option>
                  <option value="manual">Manual</option>
                </AvSelect>
                <AvInput label="Seats" name="seats" type="number" min="1" step="1" x-model="addCarForm.seats" />
              </div>

              <div class="app-form-grid">
                <AvInput label="Odometer km" name="odometerKm" type="number" min="0" step="1" x-model="addCarForm.odometerKm" />
                <AvInput
                  label="Insurance expiry"
                  name="insuranceExpiryDate"
                  type="date"
                  x-model="addCarForm.insuranceExpiryDate"
                />
                <AvInput
                  label="Registration expiry"
                  name="registrationExpiryDate"
                  type="date"
                  x-model="addCarForm.registrationExpiryDate"
                />
              </div>
            </form>

            <Fragment slot="notice">
              <template x-if="getDrawerError()">
                <div class="av-alert av-alert-danger" role="status" x-text="getDrawerError()"></div>
              </template>
            </Fragment>

            <Fragment slot="actions">
              <AvButton variant="ghost" type="button" @click="closeAddCarDrawer()">Cancel</AvButton>
              <AvButton type="submit" form="add-car-form" :disabled="isSaving">
                <span x-text="isSaving ? 'Saving...' : 'Save Car'"></span>
              </AvButton>
            </Fragment>
          </CreateDrawer>
        </template>

        <template x-if="isAddCustomerDrawerOpen()">
          <CreateDrawer title="Add Customer" description="Create one customer record for your business.">
            <form id="add-customer-form" class="av-auth-stack-md" novalidate @submit.prevent="submitAddCustomer()">
              <div class="app-field-stack">
                <AvInput
                  label="Full name"
                  name="fullName"
                  x-model="addCustomerForm.fullName"
                  x-on:input="clearCustomerFieldError('fullName')"
                  required
                  placeholder="e.g. Priya Raman"
                />
                <template x-if="getCustomerFieldError('fullName')">
                  <p class="app-field-error" x-text="getCustomerFieldError('fullName')"></p>
                </template>
              </div>

              <div class="app-form-grid">
                <AvInput label="Phone" name="phone" x-model="addCustomerForm.phone" />
                <AvInput label="Email" name="email" type="email" x-model="addCustomerForm.email" />
              </div>

              <div class="app-form-grid">
                <AvInput label="Document type" name="documentType" x-model="addCustomerForm.documentType" />
                <AvInput label="Document number" name="documentNumber" x-model="addCustomerForm.documentNumber" />
              </div>

              <AvTextarea
                label="Notes"
                name="notes"
                rows={4}
                x-model="addCustomerForm.notes"
                placeholder="Internal notes"
              />
            </form>

            <Fragment slot="notice">
              <template x-if="getCustomerDrawerError()">
                <div class="av-alert av-alert-danger" role="status" x-text="getCustomerDrawerError()"></div>
              </template>
            </Fragment>

            <Fragment slot="actions">
              <AvButton variant="ghost" type="button" @click="closeAddCustomerDrawer()">Cancel</AvButton>
              <AvButton type="submit" form="add-customer-form" :disabled="isSavingCustomer">
                <span x-text="isSavingCustomer ? 'Saving...' : 'Save Customer'"></span>
              </AvButton>
            </Fragment>
          </CreateDrawer>
        </template>
      </div>
    </AvContainer>
  </section>
</AppShell>
